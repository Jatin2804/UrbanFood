# GitHub Token for storing user data and orders
EXPO_PUBLIC_GITHUB_TOKEN=your_github_token_here

# OpenRouteService API Key for maps and routing
EXPO_PUBLIC_ORS_API_KEY=your_ors_api_key_here

# Google Maps API Key (optional, for development)
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# xAI API Key (if using xAI chatbot)
EXPO_PUBLIC_XAI_API_KEY=your_xai_api_key_here

# Groq API Key for chatbot functionality
EXPO_PUBLIC_GROQ_API_KEY=your_groq_api_key_here
